@model List<SonarCubewithDotNet.Models.Employee>


@{
    ViewData["Title"] = "Employees";
}


<h1>Employees</h1>


<table class="table table-bordered">

<thead>

<tr>
    <th>ID</th>
    <th>Name</th>
    <th>Department</th>
    <th>Salary</th>
</tr>

</thead>


<tbody>

@foreach(var employee in Model)
{
    <tr>

        <td>
            @employee.Id
        </td>

        <td>
            @employee.Name
        </td>

        <td>
            @employee.Department
        </td>

        <td>
            @employee.Salary
        </td>

    </tr>
}

</tbody>

</table>